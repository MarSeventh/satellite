{
  "productName": "Satellite",
  "version": "0.1.37",
  "identifier": "com.satellite.imgbed",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Satellite",
        "width": 900,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "visible": true,
        "center": true,
        "transparent": false,
        "decorations": true,
        "dragDropEnabled": true
      },
      {
        "label": "floating",
        "title": "",
        "url": "/",
        "width": 84,
        "height": 84,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "x": 48,
        "y": 188,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: http: data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
